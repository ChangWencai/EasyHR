/* mine.wxss */
.profile-card { text-align: center; }
.avatar-area { display: flex; flex-direction: column; align-items: center; }
.avatar { width: 64px; height: 64px; border-radius: 50%; background: #1677FF; color: #fff; font-size: 28px; font-weight: 600; display: flex; align-items: center; justify-content: center; margin-bottom: 8px; }
.name-row { display: flex; align-items: center; gap: 8px; }
.profile-name { font-size: 18px; font-weight: 600; }
.role-badge { background: #E6F4FF; color: #1677FF; font-size: 12px; padding: 2px 8px; border-radius: 4px; }
.info-card { padding: 4px 0; }
.info-row { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid #f5f5f5; font-size: 14px; }
.info-row:last-child { border-bottom: none; }
.info-label { color: #666; }
.info-value { color: #333; }
.btn-danger { background: #fff; color: #FF4D4F; border: 1px solid #FF4D4F; width: 100%; }
