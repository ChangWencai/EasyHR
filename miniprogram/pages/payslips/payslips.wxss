/* payslips.wxss */
.payslip-card { border-left: 3px solid #1677FF; }
.payslip-month { font-size: 16px; font-weight: 600; margin-bottom: 8px; }
.payslip-row { display: flex; justify-content: space-between; align-items: center; }
.payslip-amount { font-size: 18px; font-weight: 600; color: #1677FF; }
.payslip-signed { font-size: 12px; color: #999; margin-top: 4px; }
.status-badge { font-size: 12px; padding: 2px 8px; border-radius: 4px; }
.status-draft, .status-pending { background: #FFFBE6; color: #FAAD14; }
.status-confirmed { background: #E6F4FF; color: #1677FF; }
.status-paid { background: #F6FFED; color: #52C41A; }
.empty-title { display: block; font-size: 16px; margin-bottom: 8px; }
.empty-desc { display: block; font-size: 14px; color: #999; }
