/* expense.wxss */
.form-card { padding: 8px; }
.form-label { font-size: 14px; color: #666; margin: 12px 0 8px; }
.picker-value { background: #f5f5f5; padding: 12px; border-radius: 4px; font-size: 16px; }
input, textarea { background: #f5f5f5; padding: 12px; border-radius: 4px; font-size: 16px; width: 100%; box-sizing: border-box; }
textarea { min-height: 80px; }
.photo-grid { display: flex; flex-wrap: wrap; gap: 8px; }
.photo-item { position: relative; width: 80px; height: 80px; }
.photo-item image { width: 100%; height: 100%; border-radius: 4px; }
.photo-del { position: absolute; top: -8px; right: -8px; width: 20px; height: 20px; background: #FF4D4F; color: #fff; border-radius: 50%; text-align: center; line-height: 20px; font-size: 14px; }
.photo-add { width: 80px; height: 80px; background: #f5f5f5; border: 1px dashed #ccc; border-radius: 4px; display: flex; align-items: center; justify-content: center; font-size: 32px; color: #999; }
.photo-tip { font-size: 12px; color: #999; margin-top: 4px; }
