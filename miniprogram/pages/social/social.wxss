/* social.wxss */
.city-row, .base-row { font-size: 14px; color: #666; margin-bottom: 4px; }
.section-title { font-size: 16px; font-weight: 600; margin-bottom: 12px; }
.social-row { display: flex; justify-content: space-between; padding: 8px 0; border-bottom: 1px solid #f5f5f5; font-size: 14px; }
.social-name { color: #333; }
.social-amount { color: #333; font-weight: 500; }
.social-total { display: flex; justify-content: space-between; padding-top: 12px; margin-top: 8px; border-top: 2px solid #1677FF; font-size: 16px; font-weight: 600; }
.total-amount { color: #1677FF; }
