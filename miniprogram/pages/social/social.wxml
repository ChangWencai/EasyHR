<!-- social.wxml -->
<view class="container">
  <view wx:if="{{loading}}" class="empty-state"><text>加载中...</text></view>
  <view wx:elif="{{!record}}" class="empty-state">
    <text class="empty-title">暂无社保缴纳记录</text>
    <text class="empty-desc">您入职后参保信息将显示在此处</text>
  </view>
  <block wx:else>
    <view class="card">
      <view class="city-row">参保城市：{{record.city}}</view>
      <view class="base-row">社保基数：¥{{record.base}}</view>
    </view>
    <view class="card">
      <view class="section-title">个人缴费明细</view>
      <view wx:for="{{record.items}}" wx:key="name" class="social-row">
        <text class="social-name">{{item.name}}</text>
        <text class="social-amount">¥{{item.personal}}</text>
      </view>
      <view class="social-total">
        <text>个人缴费合计</text><text class="total-amount">¥{{record.total_personal}}</text>
      </view>
    </view>
  </block>
</view>
