page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
  font-size: 16px;
  color: #333;
  line-height: 1.5;
}
.container { padding: 16px; }
.card {
  background: #fff;
  border-radius: 8px;
  padding: 16px;
  margin-bottom: 12px;
}
.btn-primary {
  background: #1677FF;
  color: #fff;
  border: none;
  border-radius: 4px;
  padding: 12px 24px;
  font-size: 16px;
  width: 100%;
}
.btn-disabled { background: #ccc; color: #fff; }
.status-pending { color: #FAAD14; }
.status-success { color: #52C41A; }
.status-danger  { color: #FF4D4F; }
.status-accent  { color: #1677FF; }
.empty-state {
  text-align: center;
  padding: 60px 16px;
  color: #999;
  font-size: 14px;
}
